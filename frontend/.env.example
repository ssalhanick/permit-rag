# frontend/.env.example — Sprint 5
# Copy to frontend/.env and fill in your values.

# Mapbox public token for address autocomplete (Sprint 5)
# Get a free token at https://account.mapbox.com/
# Must start with pk.* (public token — safe to expose in frontend)
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# API base URL (override for staging/production)
# VITE_API_BASE_URL=http://localhost:8000

# Future (Sprint 6+): when Google Maps API key is obtained, replace Mapbox:
# VITE_GOOGLE_MAPS_API_KEY=AIza...
# See docs/backlog.md — "Blocking Condition for Google Maps Upgrade"
