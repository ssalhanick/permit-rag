# frontend/.env.local — Vite dev-only (auto-loaded by npm run dev)
# Copy to frontend/.env.local

# Mapbox public token (pk.* — safe in frontend)
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_TOKEN_HERE

# Leave unset — api.js uses http://localhost:8000 on localhost automatically
# VITE_API_BASE_URL=http://localhost:8000
