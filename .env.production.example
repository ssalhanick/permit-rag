# .env.production — optional local debugging against AWS RDS
# NOT used on ECS (Terraform injects DATABASE_URL + secrets there).
# Only loaded when ENVIRONMENT=production on your laptop.
#
# Copy to .env.production and fill RDS endpoint from Terraform output.
# Start API with: $env:ENVIRONMENT="production"; py -m uvicorn api.main:app --reload --port 8000

ENVIRONMENT=production
LOG_LEVEL=INFO

DATABASE_URL=postgresql://postgres:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/permit_rag
CORPUS_WRITER_URL=postgresql://postgres:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/permit_rag
APP_READER_URL=postgresql://postgres:YOUR_RDS_PASSWORD@YOUR_RDS_ENDPOINT:5432/permit_rag

# Prod CORS — CloudFront serves frontend + API on same domain
API_CORS_ALLOW_LOCALHOST=false
API_CORS_ALLOW_ALL=false
API_CORS_ALLOW_ORIGINS=https://permits.scottsalhanick.com

LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
