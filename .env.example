# ── Postgres (local) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:your-password@localhost:5433/permit_rag

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Application ───────────────────────────────────────────
# Model used for RAG generation
LLM_MODEL=claude-sonnet-4-20250514
# Model used for embeddings (local via sentence-transformers)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── Budget guards ─────────────────────────────────────────
# Max spend per harvest run (USD)
HARVEST_BUDGET_USD=5.00

# ── Environment ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
