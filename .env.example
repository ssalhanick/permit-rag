# .env — shared secrets (copy from .env.example)
# Loaded on top of .env.local (local) or .env.production (RDS debug).
# On ECS, secrets come from SSM — this file is not in the container.
#
# Setup:
#   Copy-Item .env.local.example .env.local
#   Copy-Item .env.example .env
# See docs/environment_setup.md

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_PROMPT_CACHE_TTL=5m

# ── API admin auth ────────────────────────────────────────
API_ADMIN_TOKEN=replace-with-long-random-token
API_ADMIN_ALLOWED_ROLES=admin,owner
API_PURGE_ANY_TIER_ROLES=owner

# ── JWT Authentication ────────────────────────────────────
API_JWT_SECRET=replace-with-secure-key-at-least-32-characters-long
API_JWT_ACCESS_TTL_MIN=15
API_JWT_REFRESH_TTL_DAYS=7

# ── LangSmith (optional, local eval tracing) ──────────────
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=permit-rag-eval

# ── RAGAS cache ───────────────────────────────────────────
RAGAS_EVAL_MAX_TOKENS=4096
RAGAS_FAITH_RETRIES=2
RAGAS_ANSWER_CACHE_PATH=evaluation/cache/answers.json
RAGAS_ANSWER_CACHE_PROMPT_VERSION=v1

# ── Mapbox (also set in frontend/.env.local) ──────────────
# VITE_MAPBOX_TOKEN is frontend-only — see frontend/.env.local.example
