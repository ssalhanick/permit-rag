# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Direct Postgres connection (for pgvector / migrations)
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Application ───────────────────────────────────────────
# Model used for RAG generation
LLM_MODEL=claude-sonnet-4-20250514
# Model used for embeddings (Voyage via Anthropic partnership, or local)
EMBEDDING_MODEL=voyage-3

# ── Budget guards ─────────────────────────────────────────
# Max spend per harvest run (USD)
HARVEST_BUDGET_USD=5.00
# Max spend per embedding batch (USD)
EMBED_BUDGET_USD=10.00

# ── Environment ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
