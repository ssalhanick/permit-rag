# ── Postgres (local) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:your-password@localhost:5433/permit_rag

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Application ───────────────────────────────────────────
# Provider used by generator/evaluator adapters
LLM_PROVIDER=anthropic
# Model used for RAG generation
LLM_MODEL=claude-...
# Model used for embeddings (local via sentence-transformers)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# Enable Anthropic prompt caching where provider capability supports it
ANTHROPIC_PROMPT_CACHE_ENABLED=false
# Anthropic prompt cache TTL (supported: 5m, 1h)
ANTHROPIC_PROMPT_CACHE_TTL=5m
# Max tokens for RAGAS evaluator LLM calls (helps avoid truncated faithfulness runs)
RAGAS_EVAL_MAX_TOKENS=4096
# Retries for faithfulness metric when evaluator output is incomplete
RAGAS_FAITH_RETRIES=2
# Enable/disable generation answer cache for eval reruns
RAGAS_ANSWER_CACHE_ENABLED=true
# JSON file used for cached generated answers
RAGAS_ANSWER_CACHE_PATH=evaluation/cache/answers.json
# Bump this to invalidate cache when prompt behavior changes
RAGAS_ANSWER_CACHE_PROMPT_VERSION=v1

# ── Budget guards ─────────────────────────────────────────
# Max spend per harvest run (USD)
HARVEST_BUDGET_USD=5.00

# ── Environment ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
