# ── Postgres (local) ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:your-password@localhost:5433/permit_rag

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Anthropic prompt cache TTL (supported: 5m, 1h)
ANTHROPIC_PROMPT_CACHE_TTL=5m

# ── Ollama ─────────────────────────────────────────────
# Ollama local model runtime settings (keep model placeholder generic)
OLLAMA_MODEL=<your-local-model>
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=180

# ── Application (single source of truth) ──────────────────
# Keep only one active value per key in your .env.
# Use the profile templates below as copy/paste presets into THIS block.
# Provider used by generator/evaluator adapters
LLM_PROVIDER=anthropic
RAGAS_EVAL_PROVIDER=anthropic
LLM_MODEL=claude-...
RAGAS_ANSWER_CACHE_ENABLED=true
ANTHROPIC_PROMPT_CACHE_ENABLED=false

# Model used for embeddings (local via sentence-transformers)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5


# Max tokens for RAGAS evaluator LLM calls (helps avoid truncated faithfulness runs)
RAGAS_EVAL_MAX_TOKENS=4096
# Retries for faithfulness metric when evaluator output is incomplete
RAGAS_FAITH_RETRIES=2

# LangSmith eval tracing (local development only; optional)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=permit-rag-eval
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# JSON file used for cached generated answers
RAGAS_ANSWER_CACHE_PATH=evaluation/cache/answers.json
# Bump this to invalidate cache when prompt behavior changes
RAGAS_ANSWER_CACHE_PROMPT_VERSION=v1

# ── Ingestion normalization controls ───────────────────────
CHUNK_NORMALIZATION_ENABLED=true
CHUNK_PROCEDURAL_FILTER_ENABLED=true
CHUNK_PROCEDURAL_DROP_THRESHOLD=3
# Warn for manual review when dropped chunk ratio exceeds this value.
CHUNK_FILTER_WARN_DROP_RATIO=0.50

# ── Retrieval procedural downranking controls ──────────────
RETRIEVAL_PROCEDURAL_PENALTY_ENABLED=true
RETRIEVAL_PROCEDURAL_PENALTY=0.015
RETRIEVAL_PROCEDURAL_MAX_HITS=4

# ── Hybrid retrieval controls (dense + BM25 RRF) ───────────
RETRIEVAL_HYBRID_ENABLED=false
RETRIEVAL_DENSE_TOP_N=20
RETRIEVAL_BM25_TOP_N=20
RETRIEVAL_RRF_K=60
# Optional branch weighting for RRF fusion.
RETRIEVAL_RRF_DENSE_WEIGHT=1.0
RETRIEVAL_RRF_BM25_WEIGHT=1.0

# ── Budget guards ─────────────────────────────────────────
# Max spend per harvest run (USD)
HARVEST_BUDGET_USD=5.00

# ── Environment ───────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Run profile templates (commented) ──────────────────────
# Copy the values you want into the Application block above.
#
# Local iteration profile (lowest API cost):
#   LLM_PROVIDER=ollama
#   RAGAS_EVAL_PROVIDER=ollama
#   OLLAMA_MODEL=<your-local-model>
#   RAGAS_ANSWER_CACHE_ENABLED=true
#   ANTHROPIC_PROMPT_CACHE_ENABLED=false
#
# Final gate profile (canonical benchmark):
#   LLM_PROVIDER=anthropic
#   RAGAS_EVAL_PROVIDER=anthropic
#   LLM_MODEL=claude-...
#   ANTHROPIC_PROMPT_CACHE_ENABLED=true
#   RAGAS_ANSWER_CACHE_ENABLED=true
