# .env.local — local development infrastructure (copy to .env.local)
# Loaded automatically when ENVIRONMENT is not production and not on ECS.
# Requires: docker compose up -d db neo4j

ENVIRONMENT=local
LOG_LEVEL=INFO

# ── Postgres (Docker on localhost:5433) ───────────────────
DATABASE_URL=postgresql://postgres:localdev@localhost:5433/permit_rag
CORPUS_WRITER_URL=postgresql://corpus_writer:changeme_rotate_corpus@localhost:5433/permit_rag
APP_READER_URL=postgresql://app_reader:changeme_rotate_reader@localhost:5433/permit_rag

# ── Neo4j (docker-compose) ────────────────────────────────
NEO4J_AUTH=neo4j/localdev123
NEO4J_BOLT_URL=bolt://localhost:7687

# ── Ollama (optional local LLM) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=180

# ── LLM defaults (local) ──────────────────────────────────
LLM_PROVIDER=anthropic
RAGAS_EVAL_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_PROMPT_CACHE_ENABLED=true
RAGAS_ANSWER_CACHE_ENABLED=true
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── CORS (Vite dev server — any localhost port) ───────────
API_CORS_ALLOW_LOCALHOST=true
API_CORS_ALLOW_ALL=false

# ── Retrieval / ingestion (same as prod defaults) ─────────
CHUNK_NORMALIZATION_ENABLED=true
CHUNK_PROCEDURAL_FILTER_ENABLED=true
RETRIEVAL_HYBRID_ENABLED=false
RETRIEVAL_MIN_RERANKED_SCORE=0.3
HARVEST_BUDGET_USD=5.00

API_ADMIN_AUTH_REQUIRED=true
